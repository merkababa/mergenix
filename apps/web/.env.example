# Mergenix Web App — Environment Variables
NEXT_PUBLIC_API_URL=http://localhost:8000

# Coming Soon Mode
SITE_COMING_SOON=true          # Set to 'true' to enable coming soon mode
# SITE_BYPASS_SECRET: password for the /coming-soon unlock form.
# Team members enter this password in the browser form; the server sets an
# HttpOnly cookie containing an HMAC-derived token (not the raw secret).
# Generate a strong secret: openssl rand -base64 32
SITE_BYPASS_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32
