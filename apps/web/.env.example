# Mergenix Web App — Environment Variables

# ── API ───────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Site URL ─────────────────────────────────────────────────
# Used for SEO metadata (canonical URLs, Open Graph). Override in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Coming Soon Mode ─────────────────────────────────────────
# Set to 'true' to enable coming soon mode
SITE_COMING_SOON=false
# Password for the /coming-soon unlock form.
# Team members enter this in the browser; the server sets an HttpOnly cookie
# containing an HMAC-derived token (not the raw secret).
# Generate with: openssl rand -base64 32
SITE_BYPASS_SECRET=

# ── Redis (production) ───────────────────────────────────────
REDIS_PASSWORD=
