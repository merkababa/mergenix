# ============================================================
# Mergenix API — Environment Variables
# Copy to .env and fill in your values.
# ============================================================

# ── Database ─────────────────────────────────────────────────
# Async PostgreSQL connection string (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://mergenix:mergenix@localhost:5432/mergenix

# ── Auth / JWT ───────────────────────────────────────────────
# REQUIRED: Secret key for signing JWT tokens. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Data Encryption ──────────────────────────────────────────
# Separate key for encrypting analysis results at rest (AES-256-GCM).
# If not set, falls back to JWT_SECRET for backward compatibility.
# IMPORTANT: Once set, do NOT change — all encrypted data becomes
# unrecoverable if this key is rotated. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
DATA_ENCRYPTION_KEY=

# ── TOTP Encryption ───────────────────────────────────────────
# REQUIRED: Fernet key for encrypting TOTP secrets at rest (AES-128-CBC + HMAC-SHA256).
# IMPORTANT: Once set, do NOT change — all stored TOTP secrets become
# unrecoverable if this key is rotated without a data migration.
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOTP_ENCRYPTION_KEY=

# ── Stripe ───────────────────────────────────────────────────
# Stripe secret key (sk_test_... for development)
STRIPE_SECRET_KEY=
# Stripe webhook signing secret (whsec_...)
STRIPE_WEBHOOK_SECRET=
# Stripe Price IDs for Premium and Pro tiers
STRIPE_PRICE_PREMIUM=
STRIPE_PRICE_PRO=

# ── Email (Resend) ───────────────────────────────────────────
# API key from https://resend.com
RESEND_API_KEY=
# "From" address for outbound emails
EMAIL_FROM=noreply@mergenix.com

# ── Google OAuth ─────────────────────────────────────────────
# OAuth 2.0 credentials from Google Cloud Console
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Application ──────────────────────────────────────────────
# Frontend URL for CORS and redirect links
FRONTEND_URL=http://localhost:3000
# Environment: development | staging | production
ENVIRONMENT=development
# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# Set to false for local development (no HTTPS); true in production
COOKIE_SECURE=false

# ── Sentry ───────────────────────────────────────────────────
# Sentry DSN for error tracking (leave empty to disable)
SENTRY_DSN=

# ── ClinVar ──────────────────────────────────────────────────
# FTP URL for ClinVar variant summary (usually no need to change)
CLINVAR_FTP_URL=https://ftp.ncbi.nlm.nih.gov/pub/clinvar/tab_delimited/variant_summary.txt.gz

# ── Admin ────────────────────────────────────────────────────
# API key for admin-only endpoints (ClinVar sync, etc.)
ADMIN_API_KEY=

# ── Redis (production) ───────────────────────────────────────
REDIS_PASSWORD=
