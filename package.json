{
  "name": "mergenix",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "test:e2e": "turbo test:e2e",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "clean": "turbo clean && rm -rf node_modules",
    "db:migrate": "cd apps/api && alembic upgrade head",
    "db:rollback": "cd apps/api && alembic downgrade -1",
    "check:carrier-panel": "node scripts/check-carrier-panel.mjs",
    "audit:npm": "pnpm audit --audit-level=high",
    "audit:pip": "cd apps/api && pip-audit -r requirements.txt",
    "audit": "pnpm audit:npm && pnpm audit:pip"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@next/eslint-plugin-next": "^15.1.0",
    "eslint": "^9.39.4",
    "next": "15.5.12",
    "prettier": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.12",
    "typescript-eslint": "^8.56.1"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.4.1",
  "pnpm": {
    "overrides": {
      "minimatch": ">=3.1.4",
      "rollup": ">=4.59.0"
    }
  }
}
