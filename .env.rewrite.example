# ─── Mergenix Rewrite — Environment Variables ───
# Copy this file to .env and fill in your values.
# This file is for the Next.js + FastAPI rewrite stack.

# ─── Database ───
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/mergenix

# ─── Authentication ───
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# ─── OAuth ───
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Stripe ───
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PREMIUM=price_...
STRIPE_PRICE_PRO=price_...
# Note: Hosted checkout does not require a client-side publishable key.
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── Email ───
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@mergenix.com

# ─── Sentry ───
SENTRY_DSN=https://...@sentry.io/...
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# ─── App ───
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:8000
ENVIRONMENT=development

# ─── ClinVar ───
CLINVAR_FTP_URL=https://ftp.ncbi.nlm.nih.gov/pub/clinvar/tab_delimited/variant_summary.txt.gz
