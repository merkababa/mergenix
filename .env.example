# Mergenix Environment Variables
# Copy this file to .env and fill in your values
#
# All settings use the MERGENIX_ prefix and are loaded by Source/config.py
# (pydantic-settings). See Source/config.py for the full list of fields.

# ---- Application ----
MERGENIX_APP_NAME=Mergenix
MERGENIX_APP_VERSION=2.0.0
MERGENIX_DEBUG=False
MERGENIX_LOG_LEVEL=INFO

# ---- Auth / Session ----
MERGENIX_SECRET_KEY=your_random_secret_key_here
MERGENIX_TOKEN_EXPIRY_HOURS=24
MERGENIX_MAX_LOGIN_ATTEMPTS=5
MERGENIX_LOCKOUT_DURATION_MINUTES=30
MERGENIX_SESSION_TIMEOUT_MINUTES=30

# ---- Google OAuth ----
# Get credentials from: https://console.cloud.google.com/apis/credentials
MERGENIX_GOOGLE_CLIENT_ID=your_google_client_id_here
MERGENIX_GOOGLE_CLIENT_SECRET=your_google_client_secret_here
MERGENIX_GOOGLE_REDIRECT_URI=http://localhost:8501/Login?oauth_callback=google

# ---- Stripe Payment ----
MERGENIX_STRIPE_SECRET_KEY=your_stripe_secret_key_here
MERGENIX_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
MERGENIX_STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here
MERGENIX_STRIPE_PRICE_ID_PREMIUM=
MERGENIX_STRIPE_PRICE_ID_PRO=

# ---- PayPal ----
MERGENIX_PAYPAL_CLIENT_ID=your_paypal_client_id_here
MERGENIX_PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here
MERGENIX_PAYPAL_WEBHOOK_ID=
MERGENIX_PAYPAL_MODE=sandbox

# ---- Database ----
MERGENIX_DATABASE_URL=sqlite:///data/mergenix.db

# ---- File Upload ----
MERGENIX_MAX_UPLOAD_SIZE_MB=200

# ---- SMTP / Email ----
MERGENIX_SMTP_HOST=smtp.sendgrid.net
MERGENIX_SMTP_PORT=587
MERGENIX_SMTP_USERNAME=apikey
MERGENIX_SMTP_PASSWORD=your-sendgrid-api-key
MERGENIX_FROM_EMAIL=noreply@mergenix.com
MERGENIX_FROM_NAME=Mergenix
MERGENIX_APP_BASE_URL=http://localhost:8501
