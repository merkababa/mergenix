# Tortit Environment Variables
# Copy this file to .env and fill in your values

# Google OAuth Configuration
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8501/Login?oauth_callback=google

# Apple OAuth Configuration (Future)
# APPLE_CLIENT_ID=your_apple_client_id_here
# APPLE_CLIENT_SECRET=your_apple_client_secret_here
# APPLE_REDIRECT_URI=http://localhost:8501/Login?oauth_callback=apple

# Stripe Payment Configuration
STRIPE_PUBLIC_KEY=your_stripe_public_key_here
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# PayPal Configuration
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here
PAYPAL_MODE=sandbox  # or 'live' for production

# Session Configuration
SESSION_TIMEOUT_MINUTES=30
SESSION_SECRET_KEY=your_random_secret_key_here

# Application Settings
DEBUG=False
LOG_LEVEL=INFO
